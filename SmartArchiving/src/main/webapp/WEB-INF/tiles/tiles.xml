<tiles-definitions>

	<!-- 유일한 레이아웃 템플릿 — 조합은 extends + put-attribute 로 제어 (sangju 방식) -->
	<definition name="layouts-base" template="/WEB-INF/tiles/layout/layout-basic.jsp">
		<put-attribute name="layoutMode" value="main"/>
		<put-attribute name="tiles_head" value="/WEB-INF/tiles/layout/head.jsp"/>
		<put-attribute name="tiles_header" value="/WEB-INF/tiles/layout/header.jsp"/>
		<put-attribute name="tiles_menu" value="/WEB-INF/views/common/includes/sideMenu.jsp"/>
		<put-attribute name="tiles_footer" value="/WEB-INF/tiles/layout/footer.jsp"/>
	</definition>

	<!-- footer 없음 -->
	<definition name="layouts-no-footer" extends="layouts-base">
		<put-attribute name="tiles_footer" value=""/>
	</definition>

	<!-- header/menu/footer 없음 (팝업, 권한신청 등) -->
	<definition name="layouts-minimal" extends="layouts-base">
		<put-attribute name="layoutMode" value="minimal"/>
		<put-attribute name="tiles_head" value="/WEB-INF/tiles/layout/head-min.jsp"/>
		<put-attribute name="tiles_header" value=""/>
		<put-attribute name="tiles_menu" value=""/>
		<put-attribute name="tiles_footer" value=""/>
	</definition>

	<!-- 로그인 -->
	<definition name="layouts-login" extends="layouts-base">
